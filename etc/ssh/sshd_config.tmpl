# Hardened SSHD bastion config -- modify wisely!
# This file is autogenerated from sshd_config.tmpl by bin/admin/openssh-config-generator.pl,
# its directives are adapted to the detected OpenSSH version.
# Based on https://wiki.mozilla.org/Security/Guidelines/OpenSSH
# With additional restrictions where applicable.
#
# Generated for OpenSSH {$verstr}
#
# -lo and -rt users only have local console login
DenyUsers *-rt
DenyUsers *-lo

# hardened params follow. every non-needed feature is disabled by default,
# following the principle of least rights and least features (more enabled
# features mean a more important attack surface).

# === FEATURES ===

# disable non-needed sshd features
AllowAgentForwarding no
AllowTcpForwarding no
AllowStreamLocalForwarding no
X11Forwarding no
PermitTunnel no
PermitUserEnvironment no
PermitUserRC no
GatewayPorts no

# === INFORMATION DISCLOSURE ===
{
    $OUT = '';    # seed: a not-taken branch below must emit nothing, not "0"
    # DebianBanner (don't advertise the distro string in the server hello) is a
    # Debian/Ubuntu-only patch keyword. On a stock sshd it is unknown and would
    # prevent sshd from starting, so we only emit it when the local sshd binary
    # actually understands it (probed at generation time).
    if ($caps{DebianBanner}) {
        $OUT .= "# don't yell to the world that we're running this distro,\n";
        $OUT .= "# this disables the distro string on the server hello message\n";
        $OUT .= "DebianBanner no\n";
    }
}
# however, display a legal notice for each connection
Banner /etc/ssh/banner

# don't print the bastion MOTD on connection
PrintMotd no

# === CRYPTOGRAPHY ===

# enforce the use of ssh version 2 protocol, version 1 is disabled.
# all sshd_config options regarding protocol 1 are therefore omitted.
Protocol 2

# only use hostkeys with secure algorithms, and omit the ones using NIST curves
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key
{
    $OUT = '';    # seed: a not-taken branch below must emit nothing, not "0"
    # OpenSSH 10.4 adds mldsa44-ed25519 (composite ML-DSA-44 + Ed25519), a
    # post-quantum host-key type. We offer it alongside the classical host keys
    # when the local build supports it (probed at generation time -- an unknown
    # key type would stop sshd from starting). The key is NOT created by
    # `ssh-keygen -A`; generate it once, as root:
    #   ssh-keygen -q -t mldsa44-ed25519 -f /etc/ssh/ssh_host_mldsa44_ed25519_key -N ''
    # until then sshd just logs that the file is missing and keeps serving the
    # classical host keys.
    if ($ver >= 1004 && $caps{mldsa44_ed25519}) {
        $OUT .= "HostKey /etc/ssh/ssh_host_mldsa44_ed25519_key\n";
        $OUT .= "HostKeyAlgorithms +mldsa44-ed25519\n";
    }
}

# list of allowed ciphers.
# chacha20-poly1305 is a modern cipher, considered very secure
# aes is still the standard, we prefer gcm cipher mode, but also
# allow ctr cipher mode for compatibility (ctr is still considered secure)
# we deny arcfour(rc4), 3des, blowfish and cast
{
    my @ciphers = $filter->('cipher', qw(
        chacha20-poly1305@openssh.com
        aes256-gcm@openssh.com
        aes128-gcm@openssh.com
        aes256-ctr
        aes192-ctr
        aes128-ctr
    ));
    $OUT .= 'Ciphers ' . join(',', @ciphers) . "\n";
}
# list of allowed message authentication code algorithms.
# etm (encrypt-then-mac) are considered the more secure, we
# prefer umac (has been proven secure) then sha2.
# for older ssh client, fallback to the non-etm version of
# the algorithms.
# we deny md5 and sha1
{
    my @macs = $filter->('mac', qw(
        umac-128-etm@openssh.com
        umac-64-etm@openssh.com
        hmac-sha2-512-etm@openssh.com
        hmac-sha2-256-etm@openssh.com
        umac-128@openssh.com
        umac-64@openssh.com
        hmac-sha2-512
        hmac-sha2-256
    ));
    $OUT .= 'MACs ' . join(',', @macs) . "\n";
}
# List of allowed key exchange algorithms.
# we prefer post-quantum hybrid KEX (mlkem768x25519-sha256 since 9.9, and
# sntrup761x25519-sha512@openssh.com since 8.5) FIRST in the list whenever the
# OpenSSH version supports them, then curve25519-sha256 which is the most
# modern/secure non-PQC kex, and still allow diffie-hellman with group exchange
# using sha256 which is the most secure dh-based kex.
# we avoid algorithms based on the disputed NIST curves, and anything based
# on sha1.
{
    my @kex;
    push @kex, 'mlkem768x25519-sha256'             if $ver >= 909;
    push @kex, 'sntrup761x25519-sha512@openssh.com' if $ver >= 805;
    push @kex, qw(
        curve25519-sha256
        curve25519-sha256@libssh.org
        diffie-hellman-group18-sha512
        diffie-hellman-group16-sha512
        diffie-hellman-group14-sha256
        diffie-hellman-group-exchange-sha256
    );
    @kex = $filter->('kex', @kex);
    $OUT .= 'KexAlgorithms ' . join(',', @kex) . "\n";
}
# refuse legacy RSA/SHA-1 ("ssh-rsa") signatures while keeping modern RSA
# (rsa-sha2-256/512). Off by default since 8.8, but pinning it also hardens
# 8.5-8.7. The directive was renamed from PubkeyAcceptedKeyTypes in 8.5.
#
# On 10.4+ builds that support it, we instead APPEND the mldsa44-ed25519
# composite post-quantum signature so clients may authenticate with such keys.
# The list accepts a single +/-/^ operator (and sshd is first-match-wins), so
# we can't both remove ssh-rsa and append mldsa44-ed25519 in one directive;
# since ssh-rsa is already disabled by default on 10.4, dropping the now-
# redundant explicit removal in favour of the append loses no hardening.
{
    if ($ver >= 1004 && $caps{mldsa44_ed25519}) {
        $OUT .= "PubkeyAcceptedAlgorithms +mldsa44-ed25519\n";
    } elsif ($ver >= 805) {
        $OUT .= "PubkeyAcceptedAlgorithms -ssh-rsa\n";
    } else {
        $OUT .= "PubkeyAcceptedKeyTypes -ssh-rsa\n";
    }
}
# force rekey every 512M of data or 6 hours of connection, whichever comes first
RekeyLimit 512M 6h

# === AUTHENTICATION ===

# we allow only public key authentication ...
PubkeyAuthentication yes
# ... not password
PasswordAuthentication no
{
    # This directive was renamed from ChallengeResponseAuthentication to KbdInteractiveAuthentication
    # in 8.7 (the old name is a deprecated alias); emit the canonical name for the
    # target version so we don't rely on a possibly-removed alias.
    if ($ver >= 807) {
        $OUT .= "# ... keyboard interactive (needed for MFA through PAM).\n";
        $OUT .= "KbdInteractiveAuthentication yes";
    } else {
        $OUT .= "# ... challenge response (needed for MFA through PAM).\n";
        $OUT .= "ChallengeResponseAuthentication yes";
    }
}
# ... not kerberos
KerberosAuthentication no
# ... not host-based
HostbasedAuthentication no
# ... and not gssapi auth.
GSSAPIAuthentication no
# GSSAPIKeyExchange is part of the GSSAPI key-exchange patch (Debian/RHEL),
# disable it below only if the local sshd server understands it.
{
    $OUT = '';    # seed: emit nothing (not "0") when the postfix-if below is false
    $OUT .= "GSSAPIKeyExchange no\n" if $caps{GSSAPIKeyExchange};
}
# just in case, we also explicitly deny empty passwords
PermitEmptyPasswords no

# this needs to be set at "yes" to allow PAM keyboard-interactive authentication,
# which is not a security issue because the AuthenticationMethods below force the use of
# either publickey or publickey+keyboard-interactive, hence password-only login is never
# possible, for root or any other account for that matter
PermitRootLogin yes

# === LOGIN ===

# disconnect after 30 seconds if user didn't log in successfully
LoginGraceTime 30

# terminate sessions whose client connection has silently died (dead TCP).
# this does NOT kill idle-but-alive interactive sessions: the ssh client answers
# these keepalive probes automatically regardless of user activity, so only truly
# dead links get reaped (~15 minutes here).
ClientAliveInterval 300
ClientAliveCountMax 3

# not more than 1 session per network connection (connection sharing with ssh client's master/shared mode)
MaxSessions 1

# maximum concurrent unauth connections to the sshd daemon
MaxStartups 50:30:500
{
    # PerSourcePenalties throttles hosts that repeatedly fail authentication.
    # It is ON by default since 9.8 (and since 10.3 also penalises attempts for
    # usernames that don't match a real account), so no directive is needed to
    # benefit from it; if a trusted management IP is ever caught by it, exempt
    # it with PerSourcePenaltyExemptList.
    if ($ver >= 1003) {
        $OUT .= "# PerSourcePenalties is on by default (>=9.8) and since 10.3 also\n";
        $OUT .= "# penalises unknown-user attempts; exempt trusted IPs via\n";
        $OUT .= "# PerSourcePenaltyExemptList if ever needed.\n";
    } elsif ($ver >= 908) {
        $OUT .= "# PerSourcePenalties throttles repeat auth failures (on by\n";
        $OUT .= "# default since 9.8); exempt trusted IPs via\n";
        $OUT .= "# PerSourcePenaltyExemptList if ever needed.\n";
    }
}

# accept LANG and LC_* vars (also includes LC_BASTION)
AcceptEnv LANG LC_*

# === SYSTEM ===

# sshd log level at verbose in auth facility for auditing purposes
LogLevel VERBOSE
SyslogFacility AUTH

# check sanity of user HOME dir before allowing user to login
StrictModes yes

# never use dns (slows down connections)
UseDNS no

# use PAM facility
UsePAM yes

# === AuthenticationMethods vs potential root OTP vs potential user MFA ===
# If 2FA has been configured for root, we force pubkey+PAM for it. If this is the case
# on your system, uncomment the next two lines (see
# https://ovh.github.io/the-bastion/installation/advanced.html#fa-root-authentication)
#Match User root
#    AuthenticationMethods publickey,keyboard-interactive:pam
# Unconditionally skip PAM auth for members of the bastion-nopam group
Match Group bastion-nopam
    AuthenticationMethods publickey
# if in one of the mfa groups AND the osh-pubkey-auth-optional group, use publickey+pam OR pam
Match Group mfa-totp-configd,mfa-password-configd Group osh-pubkey-auth-optional
    AuthenticationMethods publickey,keyboard-interactive:pam keyboard-interactive:pam
# if in one of the mfa groups, use publickey AND pam
Match Group mfa-totp-configd,mfa-password-configd
    AuthenticationMethods publickey,keyboard-interactive:pam
# by default, always ask the publickey (no PAM)
Match All
    AuthenticationMethods publickey
